{
  "name": "orchestra",
  "version": "0.1.0",
  "description": "Multi-project AI agent orchestrator. Self-hosted Symphony for indie hackers.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check-rs",
    "check:ts": "tsgo",
    "lint": "oxlint .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ci": "pnpm fmt:check && pnpm lint && pnpm check && pnpm check:ts && pnpm test"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "oxfmt": "^0.5.0",
    "oxlint": "^0.16.0",
    "svelte": "^5.0.0",
    "svelte-check-rs": "^0.4.0",
    "tsgo": "^0.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.38.0",
    "pino": "^9.0.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
